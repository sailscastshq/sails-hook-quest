{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "maxNodeModuleJsDepth": 0,
    "strict": false,
    "skipLibCheck": true
  },
  "include": ["lib/**/*.js", "typecheck/**/*.js"],
  "exclude": ["node_modules"]
}
